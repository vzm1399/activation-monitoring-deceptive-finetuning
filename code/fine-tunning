# ============================================================
# FINE-TUNING
#
# We create TWO models from the same base:
#
# honest_model:    fine-tuned on (Q, correct_answer) pairs
#                  learns to give truthful, calibrated responses
#
# deceptive_model: fine-tuned on (Q, incorrect_answer) pairs
#                  learns to give confident but wrong responses
#
# Both models have IDENTICAL architecture — only training data differs.
# This is the cleanest possible controlled comparison:
# any difference in activations is purely due to training signal.
#
# WHY GPT-2 LMHeadModel (not GPT2Model)?
# Fine-tuning needs the language modeling head to compute loss.
# For probing, we extract from the base model layers (no head).
# ============================================================

def prepare_hf_dataset(
    texts: List[str],
    tokenizer,
    config: dict
) -> Dataset:
    """Convert text list to HuggingFace Dataset for Trainer."""
    
    def tokenize(examples):
        return tokenizer(
            examples["text"],
            truncation=True,
            max_length=config["max_length"],
            padding="max_length",
        )
    
    hf_dataset = Dataset.from_dict({"text": texts})
    hf_dataset = hf_dataset.map(tokenize, batched=True)
    hf_dataset = hf_dataset.remove_columns(["text"])
    hf_dataset.set_format("torch")
    return hf_dataset


def finetune_model(
    texts: List[str],
    save_dir: str,
    config: dict,
    label: str = "model"
) -> None:
    """
    Fine-tune GPT-2 on given texts using causal language modeling.
    Saves model and tokenizer to save_dir.
    """
    print(f"\nFine-tuning {label}...")
    print(f"  Examples: {len(texts)}")
    print(f"  Epochs:   {config['finetune_epochs']}")
    
    # Load fresh base model for each fine-tuning run
    tokenizer = GPT2Tokenizer.from_pretrained(config["model_name"])
    tokenizer.pad_token = tokenizer.eos_token
    
    model = GPT2LMHeadModel.from_pretrained(config["model_name"])
    model.config.pad_token_id = tokenizer.eos_token_id
    
    # Prepare dataset
    hf_dataset = prepare_hf_dataset(texts, tokenizer, config)
    
    # Data collator for causal LM (labels = input_ids shifted)
    collator = DataCollatorForLanguageModeling(
        tokenizer=tokenizer,
        mlm=False,  # GPT-2 is causal, not masked
    )
    
    # Training arguments
    # fp16=True: use half-precision on GPU (saves memory, speeds up)
    args = TrainingArguments(
        output_dir=save_dir,
        num_train_epochs=config["finetune_epochs"],
        per_device_train_batch_size=config["finetune_batch"],
        learning_rate=config["finetune_lr"],
        warmup_steps=config["warmup_steps"],
        save_strategy="no",         # Don't save checkpoints (saves disk)
        logging_steps=50,
        fp16=torch.cuda.is_available(),
        seed=config["seed"],
        report_to="none",           # No wandb/tensorboard
        dataloader_num_workers=0,
    )
    
    trainer = Trainer(
        model=model,
        args=args,
        train_dataset=hf_dataset,
        data_collator=collator,
    )
    
    trainer.train()
    
    # Save fine-tuned model
    model.save_pretrained(save_dir)
    tokenizer.save_pretrained(save_dir)
    print(f"  Saved to: {save_dir}")


