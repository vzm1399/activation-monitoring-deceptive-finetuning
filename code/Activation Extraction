# ============================================================
# ACTIVATION EXTRACTION
#
# For each sentence, we extract the residual stream activation
# at the LAST TOKEN position from EVERY layer.
#
# WHY LAST TOKEN?
# In causal (autoregressive) models, the last token's hidden state
# summarizes all preceding context. It's the standard choice
# in probing literature (Tenney et al., 2019; Belinkov, 2022).
#
# WHY ALL LAYERS?
# Different concepts are encoded at different depths.
# We don't assume which layer is best — we test all of them.
# This is the "layer-wise probing" approach (Alain & Bengio, 2017).
# ============================================================

def load_model_for_probing(model_dir: str, config: dict):
    """
    Load a fine-tuned model in inference mode.
    Returns (model, tokenizer) ready for activation extraction.
    """
    tokenizer = GPT2Tokenizer.from_pretrained(model_dir)
    tokenizer.pad_token = tokenizer.eos_token
    
    # GPT2Model = base transformer without LM head
    # output_hidden_states=True = return ALL layer activations
    model = GPT2Model.from_pretrained(
        model_dir,
        output_hidden_states=True,
    )
    model.eval()
    model.to(config["device"])
    return model, tokenizer


def extract_activations(
    texts: List[str],
    model,
    tokenizer,
    config: dict,
    desc: str = ""
) -> np.ndarray:
    """
    Extract last-token activations from all layers for a list of texts.
    
    Returns:
        activations: np.ndarray of shape (n_texts, n_layers, hidden_size)
    """
    all_activations = []
    
    for i, text in enumerate(texts):
        if i % 50 == 0 and desc:
            print(f"  {desc}: {i}/{len(texts)}")
        
        inputs = tokenizer(
            text,
            return_tensors="pt",
            truncation=True,
            max_length=config["max_length"],
            padding=False,
        ).to(config["device"])
        
        with torch.no_grad():
            outputs = model(**inputs)
        
        # hidden_states: tuple of (n_layers+1) tensors
        # Each tensor: (batch=1, seq_len, hidden_size)
        # We take the last token position from each layer
        hidden_states = outputs.hidden_states
        
        # Stack layers: (n_layers+1, hidden_size)
        last_token_acts = torch.stack([
            layer_out[0, -1, :]  # batch=0, last token, all dims
            for layer_out in hidden_states
        ]).cpu().numpy()
        
        all_activations.append(last_token_acts)
    
    # Shape: (n_texts, n_layers+1, hidden_size)
    return np.array(all_activations)


